{
  "name": "grpc-kv-nodejs",
  "version": "1.0.0",
  "description": "Node.js gRPC KV client/server with mTLS",
  "main": "node-kv-server.js",
  "scripts": {
    "server": "node node-kv-server.js",
    "client": "node node-kv-client.js",
    "proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./proto --grpc_out=grpc_js:./proto --proto_path=../proto ../proto/kv.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "grpc-tools": "^1.12.4"
  }
}
